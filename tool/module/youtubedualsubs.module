🍿️ DualSubs.YouTubeMusic.Translate.Lyrics.response.proto = type=http-response,script-path=https://github.com/DualSubs/Universal/releases/latest/download/Translate.response.bundle.js,pattern=^https?:\/\/youtubei\.googleapis\.com\/youtubei\/v1\/browse\?(.*)subtype=Translate,requires-body=true,binary-body-mode=true,argument="{"Type":"{{{[字幕]启用类型}}}","Type":"{{{[歌词]启用类型}}}","AutoCC":{{{[字幕]自动显示}}},"Position":"{{{[字幕]主语言(源语言)字幕位置}}}","Vendor":"{{{[翻译器]服务商API}}}","ShowOnly":{{{[翻译器]只显示"自动翻译"字幕}}},"LogLevel":"{{{调试日志等级}}}"}"

[MITM]
hostname = %APPEND% www.youtube.com, m.youtube.com, tv.youtube.com, music.youtube.com, youtubei.googleapis.com, -redirector*.googlevideo.com, *.googlevideo.com
